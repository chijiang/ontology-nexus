# ============================================
# Ontology-Nexus Environment Configuration
# Copy this file to .env and fill in the values
# ============================================

# Backend
HOST=0.0.0.0
PORT=8000

# Security - REQUIRED: Generate a strong random key (e.g., `openssl rand -hex 32`)
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS origins (JSON array or comma-separated)
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Database - REQUIRED: Set a strong password
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=kg_agent

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api
BACKEND_URL=http://localhost:8000
